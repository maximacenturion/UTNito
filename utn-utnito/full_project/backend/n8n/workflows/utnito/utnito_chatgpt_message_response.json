    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const content = $json?.message?.content;\nlet parsedData;\n\ntry {\n  parsedData = typeof content === 'string' ? JSON.parse(content) : content;\n} catch (_error) {\n  throw new Error('Invalid AI response JSON');\n}\n\nconst assistantMessage = parsedData?.assistantMessage;\n\nif (typeof assistantMessage !== 'string' || !assistantMessage.trim()) {\n  throw new Error('assistantMessage is required');\n}\n\nreturn {\n  action: 'chatGPT_message_response',\n  error: false,\n  data: {\n    assistantMessage: assistantMessage.trim()\n  },\n  origin: 'n8n'\n};"
      },
