N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=utn_ai_admin
N8N_BASIC_AUTH_PASSWORD=utn_ai_admin_password
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Ollama base URL used by n8n workflows
# Default (Docker): http://chat-ollama:11434
# Local host Ollama: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://chat-ollama:11434
